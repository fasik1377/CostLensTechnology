# ═══════════════════════════════════════════════════
# CostLens Backend — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Server ──
NODE_ENV=development
PORT=4000
FRONTEND_URL=https://costlens.technology

# ── PostgreSQL Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=costlens
DB_USER=costlens_admin
DB_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://costlens_admin:your_secure_password_here@localhost:5432/costlens

# ── JWT Authentication ──
JWT_SECRET=your_jwt_secret_min_32_chars_here_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Anthropic API ──
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
ANTHROPIC_PRIMARY_MODEL=claude-opus-4-6
ANTHROPIC_FALLBACK_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_FAST_MODEL=claude-sonnet-4-20250514

# ── Razorpay Payment ──
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX_REQUESTS=10

# ── Email (future) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=founder@costlens.technology
SMTP_PASS=your_app_password

# ── Admin ──
ADMIN_EMAIL=pratap.ranjan@yahoo.co.in
WEBHOOK_URL=
